NUXT_PUBLIC_NAME_APPLICATION=VolleyTrack
NUXT_PUBLIC_TAWKTO=

GRAPHQL_ENDPOINT=http://graphql.volleytrack.local/graphql
API_ENDPOINT=http://graphql.volleytrack.local
NUXT_PUBLIC_CENTRAL_API_TOKEN=$2y$10$5KmFUsrIWJgxJeZ7DZEyQuHCoZ8Ux9n90QBTZvSfZEDHMf5dPZpja

# Stripe Configuration
# Copie este arquivo para .env e preencha com suas chaves

NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NUXT_STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret (opcional)
NUXT_PUBLIC_STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Environment
NODE_ENV=development

# Hosts permitidos pelo Vite (opcional, separados por vírgula)
# Padrão já inclui: localhost, .volleytrack.local, .volleytrack.com
NUXT_ALLOWED_HOSTS=.volleytrack.local,.volleytrack.com
